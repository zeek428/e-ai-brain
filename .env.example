APP_ENV=local
APP_SECRET_KEY=change-me-in-local-env
ALLOW_SEEDED_USERS=
ACCESS_TOKEN_EXPIRE_SECONDS=28800

DATABASE_URL=postgresql://ai_brain:ai_brain_password@postgres:5432/ai_brain
PERSISTENCE_MODE=postgres
PGVECTOR_IMAGE=e-ai-brain-postgres-pgvector:0.8.2-pg18-trixie
POSTGRES_DB=ai_brain
POSTGRES_USER=ai_brain
POSTGRES_PASSWORD=ai_brain_password
REDIS_URL=redis://redis:6379/0

MODEL_GATEWAY_BASE_URL=
MODEL_GATEWAY_API_KEY=
MODEL_GATEWAY_DEFAULT_CHAT_MODEL=local-chat
MODEL_GATEWAY_DEFAULT_EMBEDDING_MODEL=local-embedding
MODEL_GATEWAY_TIMEOUT_SECONDS=60
MODEL_GATEWAY_MAX_RETRIES=1
GBRAIN_BASE_URL=
GBRAIN_API_KEY=
CODE_REVIEW_EXECUTOR_TYPE=claude_code_skill
CODE_REVIEW_EXECUTOR_NAME=code-review
CODE_REVIEW_EXECUTOR_COMMAND=
CODE_REVIEW_EXECUTOR_TIMEOUT_SECONDS=180
VECTOR_DIMENSION=1536

UMI_APP_API_BASE_URL=http://localhost:8000

# DingTalk login is optional. Keep disabled or incomplete to hide the login entry.
DINGTALK_LOGIN_ENABLED=false
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
DINGTALK_CLIENT_SECRET_REF=
DINGTALK_REDIRECT_URI=
DINGTALK_BIND_REDIRECT_URI=
DINGTALK_ALLOWED_CORP_IDS=
DINGTALK_AUTO_PROVISION=false
DINGTALK_AUTO_PROVISION_ROLE=viewer
DINGTALK_PENDING_APPROVAL=false
DINGTALK_FRONTEND_BASE_URL=http://localhost:5173
DINGTALK_FRONTEND_CALLBACK_PATH=/login/dingtalk/callback
DINGTALK_AUTH_URL=https://login.dingtalk.com/oauth2/auth
DINGTALK_TOKEN_URL=https://api.dingtalk.com/v1.0/oauth2/userAccessToken
DINGTALK_USERINFO_URL=https://api.dingtalk.com/v1.0/contact/users/me

READINESS_API_BASE_URL=http://localhost:8000
READINESS_DOCKER_BIN=
READINESS_BEARER_TOKEN=
READINESS_USERNAME=admin@example.com
READINESS_PASSWORD=admin123
READINESS_GITLAB_REPOSITORY_ID=
READINESS_GITLAB_MR_IID=
READINESS_REQUIREMENT_ID=
READINESS_TECHNICAL_SOLUTION_TASK_ID=
